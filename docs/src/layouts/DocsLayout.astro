---
import '../../../css/groundwork.css';
import { docsNavSections } from '../docs-registry';

const { title: directTitle, description: directDescription, frontmatter } = Astro.props;
const title = directTitle ?? frontmatter?.title;
const description = directDescription ?? frontmatter?.description;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Groundwork</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      // Apply the brand theme before first paint (no flash). Accepts ?gw-theme= for
      // shareable/screenshot URLs, else the persisted choice. Light/dark stays driven
      // by prefers-color-scheme, per brand.
      (function () {
        try {
          var param = new URLSearchParams(window.location.search).get('gw-theme');
          var theme = param !== null ? param : localStorage.getItem('gw-theme');
          if (theme) document.documentElement.setAttribute('data-gw-theme', theme);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="gw-skip-link">Skip to main content</a>
    <header class="docs-header">
      <div class="docs-shell">
        <a class="docs-brand" href="/">Groundwork</a>
        <p class="gw-caption">Design System v0.2 PoC</p>
        <div class="docs-theme-switch">
          <label for="docs-theme" class="docs-theme-switch__label">Brand</label>
          <select id="docs-theme" class="gw-select">
            <option value="">Default</option>
            <option value="warm-editorial">Warm editorial</option>
            <option value="precision">Precision</option>
            <option value="confident">Confident</option>
            <option value="technical">Technical</option>
            <option value="solid">Solid</option>
            <option value="midnight">Midnight</option>
          </select>
        </div>
      </div>
    </header>

    <div class="docs-shell docs-layout">
      <aside class="docs-sidebar">
        <nav class="docs-primary-nav" aria-label="Documentation">
          {
            docsNavSections.map((section) => (
              <section class="docs-nav-section" aria-labelledby={`docs-nav-${section.heading.toLowerCase()}`}>
                <h2 class="docs-nav-heading" id={`docs-nav-${section.heading.toLowerCase()}`}>
                  {section.heading}
                </h2>
                <div class="docs-nav-links">
                  {section.links.map((link) => (
                    <a href={link.href} aria-current={currentPath === link.href ? 'page' : undefined}>
                      {link.label}
                    </a>
                  ))}
                </div>
              </section>
            ))
          }
        </nav>
      </aside>

      <main id="main" class="docs-main">
        <slot />
      </main>
    </div>

    <script>
      const select = document.getElementById('docs-theme');
      if (select instanceof HTMLSelectElement) {
        select.value = document.documentElement.getAttribute('data-gw-theme') ?? '';
        select.addEventListener('change', () => {
          const root = document.documentElement;
          if (select.value) {
            root.setAttribute('data-gw-theme', select.value);
            try {
              localStorage.setItem('gw-theme', select.value);
            } catch {}
          } else {
            root.removeAttribute('data-gw-theme');
            try {
              localStorage.removeItem('gw-theme');
            } catch {}
          }
        });
      }
    </script>
  </body>
</html>

<style is:global>
  astro-island {
    display: block;
  }

  /*
   * Astro injects an inline `astro-island { display: contents }` rule per
   * page when hydrating client:load components. That rule beats the
   * stylesheet rule above on tied specificity + document order, so margin
   * selectors targeting astro-island have no visual effect. Bump
   * specificity here so prose spacing applies through the hydration
   * wrapper.
   */
  .gw-prose > astro-island {
    display: block;
  }

  .docs-header {
    border-bottom: var(--border-width-thin) solid var(--border);
  }

  .docs-shell {
    max-width: 1280px;
    margin-inline: auto;
    padding-inline: var(--space-6);
  }

  .docs-header .docs-shell {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    align-items: baseline;
    padding-block: var(--space-4);
  }

  .docs-brand {
    color: var(--ink);
    font-size: var(--text-subheading);
    font-weight: 700;
    text-decoration: none;
  }

  .docs-theme-switch {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .docs-theme-switch__label {
    font-size: var(--text-caption);
    font-weight: 600;
    color: var(--ink-secondary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .docs-theme-switch .gw-select {
    width: auto;
    min-width: 11rem;
  }

  .docs-layout {
    display: grid;
    grid-template-columns: 13rem minmax(0, 1fr);
    gap: var(--space-8);
    align-items: start;
  }

  .docs-sidebar {
    position: sticky;
    top: 0;
    padding-block: var(--space-8);
  }

  .docs-primary-nav {
    display: grid;
    gap: var(--space-6);
    font-size: var(--text-secondary);
  }

  .docs-nav-section {
    display: grid;
    gap: var(--space-2);
  }

  .docs-nav-heading {
    margin: 0;
    color: var(--ink-secondary);
    font-size: var(--text-caption);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .docs-nav-links {
    display: grid;
    gap: var(--space-1);
  }

  .docs-nav-links a {
    display: block;
    padding: var(--space-1) var(--space-2);
    border-left: var(--border-width-medium) solid transparent;
    color: var(--action);
    text-decoration: none;
  }

  .docs-nav-links a:hover {
    text-decoration: underline;
  }

  .docs-nav-links a[aria-current='page'] {
    border-left-color: var(--action);
    color: var(--ink);
    font-weight: 700;
    text-decoration: none;
  }

  .docs-main .gw-width {
    margin-inline: 0;
  }

  @media (max-width: 760px) {
    .docs-layout {
      display: block;
    }

    .docs-sidebar {
      position: static;
      padding-block: var(--space-6) 0;
    }

    .docs-primary-nav {
      grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
      gap: var(--space-4);
    }
  }
</style>
