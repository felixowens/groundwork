---
import '../../../css/groundwork.css';
import { docsNavSections } from '../docs-registry';

const { title: directTitle, description: directDescription, frontmatter } = Astro.props;
const title = directTitle ?? frontmatter?.title;
const description = directDescription ?? frontmatter?.description;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Groundwork</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <a href="#main" class="gw-skip-link">Skip to main content</a>
    <header class="docs-header">
      <div class="docs-shell">
        <a class="docs-brand" href="/">Groundwork</a>
        <p class="gw-caption">Design System v0.2 PoC</p>
      </div>
    </header>

    <div class="docs-shell docs-layout">
      <aside class="docs-sidebar">
        <nav class="docs-primary-nav" aria-label="Documentation">
          {
            docsNavSections.map((section) => (
              <section class="docs-nav-section" aria-labelledby={`docs-nav-${section.heading.toLowerCase()}`}>
                <h2 class="docs-nav-heading" id={`docs-nav-${section.heading.toLowerCase()}`}>
                  {section.heading}
                </h2>
                <div class="docs-nav-links">
                  {section.links.map((link) => (
                    <a href={link.href} aria-current={currentPath === link.href ? 'page' : undefined}>
                      {link.label}
                    </a>
                  ))}
                </div>
              </section>
            ))
          }
        </nav>
      </aside>

      <main id="main" class="docs-main">
        <slot />
      </main>
    </div>
  </body>
</html>

<style is:global>
  astro-island {
    display: block;
  }

  /*
   * Astro injects an inline `astro-island { display: contents }` rule per
   * page when hydrating client:load components. That rule beats the
   * stylesheet rule above on tied specificity + document order, so margin
   * selectors targeting astro-island have no visual effect. Bump
   * specificity here so prose spacing applies through the hydration
   * wrapper.
   */
  .gw-prose > astro-island {
    display: block;
  }

  .docs-header {
    border-bottom: var(--border-width-thin) solid var(--border);
  }

  .docs-shell {
    max-width: 1280px;
    margin-inline: auto;
    padding-inline: var(--space-6);
  }

  .docs-header .docs-shell {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    align-items: baseline;
    padding-block: var(--space-4);
  }

  .docs-brand {
    color: var(--ink);
    font-size: var(--text-subheading);
    font-weight: var(--font-weight-bold);
    text-decoration: none;
  }

  .docs-layout {
    display: grid;
    grid-template-columns: 13rem minmax(0, 1fr);
    gap: var(--space-8);
    align-items: start;
  }

  .docs-sidebar {
    position: sticky;
    top: 0;
    padding-block: var(--space-8);
  }

  .docs-primary-nav {
    display: grid;
    gap: var(--space-6);
    font-size: var(--text-secondary);
  }

  .docs-nav-section {
    display: grid;
    gap: var(--space-2);
  }

  .docs-nav-heading {
    margin: 0;
    color: var(--ink-secondary);
    font-size: var(--text-caption);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .docs-nav-links {
    display: grid;
    gap: var(--space-1);
  }

  .docs-nav-links a {
    display: block;
    padding: var(--space-1) var(--space-2);
    border-left: var(--border-width-medium) solid transparent;
    color: var(--action);
    text-decoration: none;
  }

  .docs-nav-links a:hover {
    text-decoration: underline;
  }

  .docs-nav-links a[aria-current='page'] {
    border-left-color: var(--action);
    color: var(--ink);
    font-weight: var(--font-weight-bold);
    text-decoration: none;
  }

  .docs-main .gw-width {
    margin-inline: 0;
  }

  @media (max-width: 760px) {
    .docs-layout {
      display: block;
    }

    .docs-sidebar {
      position: static;
      padding-block: var(--space-6) 0;
    }

    .docs-primary-nav {
      grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
      gap: var(--space-4);
    }
  }
</style>
