---
import { CodeBlock } from '../../../../src';
import DocsLayout from '../../layouts/DocsLayout.astro';
import TokenList from '../../components/TokenList.astro';
import TypeSpecimen from '../../components/TypeSpecimen.astro';

interface TypeSpec {
  readonly sampleClass: string;
  readonly token: string;
  readonly value: string;
  readonly description: string;
}

const headingScale: readonly TypeSpec[] = [
  { sampleClass: 'gw-heading-xl', token: '--text-display', value: '4rem / 64px', description: 'Display — reserved for marketing or hero copy.' },
  { sampleClass: 'gw-heading-l', token: '--text-title', value: '3rem / 48px', description: 'Page title — applied to <code class="gw-code">&lt;h1&gt;</code> by default.' },
  { sampleClass: 'gw-heading-m', token: '--text-heading', value: '2.25rem / 36px', description: 'Section heading — applied to <code class="gw-code">&lt;h2&gt;</code> by default.' },
  { sampleClass: 'gw-heading-s', token: '--text-subheading', value: '1.5rem / 24px', description: 'Subheading — applied to <code class="gw-code">&lt;h3&gt;</code> by default.' },
];

const bodyScale: readonly TypeSpec[] = [
  { sampleClass: 'gw-body', token: '--text-body', value: '1.1875rem / 19px', description: 'Body — default reading size for paragraph copy.' },
  { sampleClass: 'gw-body--sm', token: '--text-secondary', value: '1rem / 16px', description: 'Secondary — supporting copy, hints, and metadata.' },
  { sampleClass: 'gw-body--xs', token: '--text-caption', value: '0.875rem / 14px', description: 'Caption — labels, eyebrow text, the smallest legible copy.' },
];

const supportingTokens = [
  { term: '<code class="gw-code">--leading-tight</code>', description: '1.25 — headings and any text where compact vertical rhythm matters.' },
  { term: '<code class="gw-code">--leading-normal</code>', description: '1.32 — body copy and any prose longer than a single line.' },
  { term: '<code class="gw-code">--measure</code>', description: '66ch — the maximum line length for comfortable reading. <code class="gw-code">.gw-prose</code> applies this automatically.' },
  { term: '<code class="gw-code">--font-sans</code>', description: 'The OS system sans-serif (<code class="gw-code">system-ui</code>). Used for every default surface — no web fonts loaded, no FOIT.' },
  { term: '<code class="gw-code">--font-mono</code>', description: 'The OS system monospace (<code class="gw-code">SF Mono</code> on macOS, falling back to <code class="gw-code">Fira Code</code> / <code class="gw-code">Fira Mono</code>). Used for code, token names, and the <code class="gw-code">.gw-code</code> utility.' },
];
---

<DocsLayout title="Typography" description="Type scale, utility classes, and the leading and measure tokens that back readable prose">
  <section class="gw-section">
    <div class="gw-width gw-stack--lg">
      <div class="gw-prose">
        <h1>Typography</h1>
        <p>Groundwork ships one type scale built on seven size tokens and two leading values. Reach for the named utility classes (<code class="gw-code">.gw-heading-*</code>, <code class="gw-code">.gw-body</code>) rather than raw size tokens — each utility bundles a size, weight, and leading. The sans-serif stack falls back through system fonts; the mono stack is reserved for code, token names, and tabular values.</p>
      </div>

      <div class="gw-prose">
        <h2>Accessibility</h2>
        <p>The minimum body size is <code class="gw-code">--text-caption</code> (14px). Do not render text smaller than this; it falls below the threshold for comfortable reading on small displays.</p>
        <p>The type scale uses <code class="gw-code">rem</code> units, so user browser zoom and root-font-size preferences scale every component proportionally. Avoid setting <code class="gw-code">font-size</code> in fixed pixels.</p>
        <p>Heading weight provides hierarchy on top of size, but the document outline must work without visual styles. Use the correct heading level (<code class="gw-code">h1</code>, <code class="gw-code">h2</code>, <code class="gw-code">h3</code>) for the section's depth — not for how big it should look.</p>
      </div>

      <section class="gw-stack" aria-labelledby="typography-headings">
        <h2 id="typography-headings">Headings</h2>
        <p class="gw-body--sm">Pair heading utilities with semantic HTML — <code class="gw-code">&lt;h1&gt;</code> with <code class="gw-code">.gw-heading-l</code>, <code class="gw-code">&lt;h2&gt;</code> with <code class="gw-code">.gw-heading-m</code>, and so on. The visual hierarchy and the document outline should agree.</p>
        <div class="gw-card">
          <ul class="docs-type-specimens gw-stack--lg" role="list">
            {headingScale.map((spec) => (
              <TypeSpecimen sampleClass={spec.sampleClass} sample="The quick brown fox" token={spec.token} value={spec.value} description={spec.description} />
            ))}
          </ul>
        </div>
      </section>

      <section class="gw-stack" aria-labelledby="typography-body">
        <h2 id="typography-body">Body text</h2>
        <p class="gw-body--sm">Body utilities cover paragraph, secondary, and caption sizes. They share the same line-height (<code class="gw-code">--leading-normal</code>) so they stack cleanly inside <code class="gw-code">.gw-prose</code>.</p>
        <div class="gw-card">
          <ul class="docs-type-specimens gw-stack--lg" role="list">
            {bodyScale.map((spec) => (
              <TypeSpecimen sampleClass={spec.sampleClass} sample="The quick brown fox jumps over the lazy dog" token={spec.token} value={spec.value} description={spec.description} />
            ))}
          </ul>
        </div>
      </section>

      <section class="gw-stack" aria-labelledby="typography-supporting">
        <h2 id="typography-supporting">Supporting tokens</h2>
        <p class="gw-body--sm">Two leading values, one ideal line length, and two font stacks.</p>
        <TokenList entries={supportingTokens} />
      </section>

      <section class="gw-stack" aria-labelledby="typography-usage">
        <h2 id="typography-usage">Using a typography utility</h2>
        <p class="gw-body--sm">Apply utility classes directly on the element. Reach for raw <code class="gw-code">--text-*</code> tokens in component CSS only when no utility fits.</p>
        <CodeBlock client:load>{`<h2>Section heading</h2>
<p class="gw-body">Default reading size.</p>
<p class="gw-body--sm">Supporting copy or hint text.</p>`}</CodeBlock>
      </section>

      <div class="gw-prose">
        <h2>Guidance</h2>
        <h3>Use heading utilities, not raw <code class="gw-code">--text-*</code> tokens</h3>
        <p>The <code class="gw-code">.gw-heading-*</code> utilities exist because a heading is a size <em>and</em> a weight <em>and</em> a leading, applied together. Reaching for <code class="gw-code">font-size: var(--text-heading)</code> in component CSS skips the weight and leading — the result looks similar but breaks visual rhythm.</p>

        <h3>Respect the measure</h3>
        <p>Lines longer than 66 characters become harder to track. Wrap prose in <code class="gw-code">.gw-prose</code> or otherwise constrain the container to <code class="gw-code">--measure</code>. Tables, code blocks, and figures are exempt.</p>

        <h3>No responsive type yet</h3>
        <p>The scale has one set of sizes; values don't shrink on small screens. If long-form pages start feeling oversized on mobile, the question is worth re-opening — but for application UI the same sizes work across viewports.</p>
      </div>

      <div class="gw-prose">
        <h2>Related</h2>
        <ul class="gw-list">
          <li><a class="gw-link" href="/styles/spacing/">Spacing</a> — vertical rhythm tokens that pair with leading.</li>
          <li><a class="gw-link" href="/styles/layout/">Layout</a> — <code class="gw-code">.gw-prose</code> applies the measure and stacks typographic blocks.</li>
        </ul>
      </div>
    </div>
  </section>
</DocsLayout>

<style>
  .docs-type-specimens {
    list-style: none;
    padding: 0;
    margin: 0;
  }
</style>
