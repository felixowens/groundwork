---
import CodeBlock from '../../components/CodeBlock.astro';
import DocsLayout from '../../layouts/DocsLayout.astro';
import Swatch from '../../components/Swatch.astro';

interface SwatchSpec {
  readonly token: string;
  readonly light: string;
  readonly dark: string;
  readonly usage: string;
}

interface GroupSpec {
  readonly id: string;
  readonly heading: string;
  readonly intro: string;
  readonly swatches: readonly SwatchSpec[];
}

const groups: readonly GroupSpec[] = [
  {
    id: 'surface',
    heading: 'Surface',
    intro:
      'Page and card backgrounds. The four surfaces give a flat hierarchy without crossing tonal boundaries between modes. Pick one elevation per region — nesting a raised card inside another flattens the hierarchy.',
    swatches: [
      { token: '--surface', light: 'oklch(100% 0 0)', dark: 'oklch(20.02% 0 0)', usage: 'Page background.' },
      { token: '--surface-raised', light: 'oklch(96.96% 0.0026 106.4)', dark: 'oklch(23.46% 0.0019 106.5)', usage: 'Cards and elevated panels.' },
      { token: '--surface-sunken', light: 'oklch(93.62% 0.0040 106.5)', dark: 'oklch(17.76% 0 0)', usage: 'Insets — input fields, code blocks, recessed regions.' },
      { token: '--surface-overlay', light: 'oklch(100% 0 0)', dark: 'oklch(35.93% 0.0034 106.6)', usage: 'Floating elements — dialogs, popovers.' },
    ],
  },
  {
    id: 'ink',
    heading: 'Ink',
    intro: 'Foreground text. Three steps cover body text, secondary copy, and disabled state.',
    swatches: [
      { token: '--ink', light: 'oklch(23.46% 0.0019 106.5)', dark: 'oklch(96.96% 0.0026 106.4)', usage: 'Primary text, headings, default body copy.' },
      { token: '--ink-secondary', light: 'oklch(47.38% 0.0047 106.6)', dark: 'oklch(71.46% 0.0043 106.5)', usage: 'Hints, captions, metadata.' },
      { token: '--ink-disabled', light: 'oklch(63.25% 0.0044 106.5)', dark: 'oklch(53.73% 0.0046 106.6)', usage: 'Labels on disabled controls. Do not use for de-emphasised live text.' },
    ],
  },
  {
    id: 'action',
    heading: 'Action',
    intro: 'Primary interactive colour — Button backgrounds, links, and other affordances the user is meant to press or follow.',
    swatches: [
      { token: '--action', light: 'oklch(53.47% 0.1360 249.9)', dark: 'oklch(70.69% 0.1103 243.4)', usage: 'Primary Button backgrounds and link text.' },
      { token: '--action-hover', light: 'oklch(41.54% 0.1030 249.8)', dark: 'oklch(80.91% 0.0956 251.8)', usage: 'Hover state for the same surfaces.' },
      { token: '--action-text', light: 'oklch(100% 0 0)', dark: 'oklch(20.02% 0 0)', usage: 'Foreground on top of <code class="gw-mono">--action</code> — tuned for contrast.' },
    ],
  },
  {
    id: 'destructive',
    heading: 'Destructive',
    intro: 'For deliberate, user-initiated destruction — deleting data, cancelling an order, reversing a transaction. Visually distinct from <code class="gw-mono">--error</code>, which signals a validation problem the system is reporting back.',
    swatches: [
      { token: '--destructive', light: 'oklch(50.16% 0.1887 27.5)', dark: 'oklch(68.75% 0.1420 21.5)', usage: 'Destructive Button backgrounds.' },
      { token: '--destructive-hover', light: 'oklch(41.16% 0.1524 27.2)', dark: 'oklch(82.19% 0.0811 19.0)', usage: 'Hover state for destructive Buttons.' },
      { token: '--destructive-text', light: 'oklch(100% 0 0)', dark: 'oklch(20.02% 0 0)', usage: 'Foreground on top of <code class="gw-mono">--destructive</code>.' },
    ],
  },
  {
    id: 'status',
    heading: 'Status',
    intro: 'Success, warning, and error states. Each ships with a paired <code class="gw-mono">-surface</code> for Banner backgrounds and similar muted treatments. Reserve these for messages where colour itself communicates state — decorating non-status content dilutes the signal.',
    swatches: [
      { token: '--success', light: 'oklch(47.84% 0.1205 154.1)', dark: 'oklch(71.85% 0.1417 144.9)', usage: 'Success indicators — icon strokes, accent lines.' },
      { token: '--success-surface', light: 'oklch(95.71% 0.0210 147.6)', dark: 'oklch(17.76% 0 0)', usage: 'Success Banner background.' },
      { token: '--warning', light: 'oklch(52.26% 0.1057 85.5)', dark: 'oklch(86.22% 0.1681 88.3)', usage: 'Warning indicators.' },
      { token: '--warning-surface', light: 'oklch(96.40% 0.0509 92.6)', dark: 'oklch(17.76% 0 0)', usage: 'Warning Banner background.' },
      { token: '--error', light: 'oklch(50.16% 0.1887 27.5)', dark: 'oklch(68.75% 0.1420 21.5)', usage: 'Validation problems — field-level errors and the ErrorSummary.' },
      { token: '--error-surface', light: 'oklch(93.83% 0.0264 17.6)', dark: 'oklch(17.76% 0 0)', usage: 'Error Banner background.' },
    ],
  },
  {
    id: 'border',
    heading: 'Border',
    intro: 'Two border weights: subtle separation between regions, and stronger separation for cards or focused elements.',
    swatches: [
      { token: '--border', light: 'oklch(86.88% 0.0054 106.5)', dark: 'oklch(35.93% 0.0034 106.6)', usage: 'Card edges, dividers, table rules.' },
      { token: '--border-strong', light: 'oklch(71.46% 0.0043 106.5)', dark: 'oklch(53.73% 0.0046 106.6)', usage: 'Form-control outlines, emphasised separators.' },
    ],
  },
  {
    id: 'focus',
    heading: 'Focus',
    intro: 'Text colour that pairs with the focus ring. The ring itself lives on the <a class="gw-link" href="/styles/focus/">Focus</a> page.',
    swatches: [
      { token: '--focus-text', light: 'oklch(23.46% 0.0019 106.5)', dark: 'oklch(20.02% 0 0)', usage: 'Foreground when an element uses the yellow focus colour as a background (rare; mostly dark mode).' },
    ],
  },
];
---

<DocsLayout title="Colour" description="The semantic colour tokens that back every component, with light and dark values side by side">
  <section class="gw-section">
    <div class="gw-width gw-stack--lg">
      <div class="gw-prose">
        <h1>Colour</h1>
        <p>Groundwork's public colour palette is a closed set of semantic tokens. Each token has a paired dark-mode value — the chip on the left is light mode, the chip on the right is dark. Components reference these tokens by name, never by underlying value: a confirmation Banner uses <code class="gw-mono">--success</code> because it signals success, not because it's green.</p>
        <p>Values are written in <code class="gw-mono">oklch()</code> for perceptual uniformity. The <a class="gw-link" href="/get-started/architecture/">architecture overview</a> explains how semantic tokens remap to primitives between modes.</p>
      </div>

      <div class="gw-prose">
        <h2>Accessibility</h2>
        <p>Every paired token is tuned for at least 4.5:1 contrast in its paired use — <code class="gw-mono">--action-text</code> on <code class="gw-mono">--action</code>, <code class="gw-mono">--ink</code> on <code class="gw-mono">--surface</code>, and so on. If you compose tokens outside these pairings, verify contrast manually against <a class="gw-link" href="https://www.w3.org/TR/WCAG22/#contrast-minimum">WCAG 2.2 SC 1.4.3</a>.</p>
        <p>Colour is never the only signal. Status banners include an icon and a heading; destructive buttons include the verb in their label; form errors include text describing the problem. The colour reinforces information that is already legible without it.</p>
      </div>

      {
        groups.map((group) => (
          <section class="gw-stack" aria-labelledby={`colour-${group.id}`}>
            <h2 id={`colour-${group.id}`}>
              {group.heading}
            </h2>
            <p class="gw-body--sm" set:html={group.intro} />
            <ul class="gw-grid" role="list">
              {group.swatches.map((swatch) => (
                <Swatch token={swatch.token} light={swatch.light} dark={swatch.dark} usage={swatch.usage} />
              ))}
            </ul>
          </section>
        ))
      }

      <section class="gw-stack" aria-labelledby="colour-usage">
        <h2 id="colour-usage">Using a colour token</h2>
        <p class="gw-body--sm">Reference tokens by name in CSS via custom properties. The dark-mode value resolves automatically when the user's system is in dark mode.</p>
        <CodeBlock>{`.notification {
  background: var(--success-surface);
  color: var(--ink);
  border: var(--border-width-thin) solid var(--success);
}`}</CodeBlock>
      </section>

      <div class="gw-prose">
        <h2>Guidance</h2>
        <h3>Distinguish destructive from error</h3>
        <p><code class="gw-mono">--destructive</code> belongs on Buttons that remove data or reverse an action — places where the user intentionally pushes the button knowing the consequence. <code class="gw-mono">--error</code> belongs on validation surfaces — places where the system tells the user something is wrong with their input. The two should not appear together in the same control.</p>

        <h3>Layer surfaces, don't stack them</h3>
        <p>Use <code class="gw-mono">--surface</code> for the page, <code class="gw-mono">--surface-raised</code> for cards, and <code class="gw-mono">--surface-sunken</code> for inset regions or input fields. Nesting a raised card inside another raised card flattens the hierarchy — pick one elevation per region.</p>

        <h3>If a colour you need isn't here</h3>
        <p>The semantic palette is intentionally narrow. Off-palette colours — chart series, illustration accents, marketing surfaces — currently have no documented escape hatch. If you find yourself reaching outside the palette, that's a signal to discuss the gap rather than inline a hex value.</p>
      </div>

      <div class="gw-prose">
        <h2>Related</h2>
        <ul class="gw-list">
          <li><a class="gw-link" href="/styles/focus/">Focus</a> — the 3px yellow ring that pairs with <code class="gw-mono">--focus-text</code>.</li>
          <li><a class="gw-link" href="/components/banner/">Banner</a> — primary consumer of the status surfaces.</li>
          <li><a class="gw-link" href="/components/button/">Button</a> — uses <code class="gw-mono">--action</code> and <code class="gw-mono">--destructive</code>.</li>
          <li><a class="gw-link" href="/get-started/architecture/">Architecture overview</a> — how semantic tokens remap to primitives between light and dark modes.</li>
        </ul>
      </div>
    </div>
  </section>
</DocsLayout>
