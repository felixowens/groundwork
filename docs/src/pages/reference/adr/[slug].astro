---
import DocsLayout from '../../../layouts/DocsLayout.astro';

interface AdrModule {
  Content: any;
  rawContent?: () => string;
}

export async function getStaticPaths() {
  const adrModules = import.meta.glob<AdrModule>('../../../../adr/*.md', { eager: true });
  return Object.entries(adrModules).map(([path, mod]) => {
    const slug = path.replace(/.*\/adr\//u, '').replace(/\.md$/u, '');
    const rawContent = typeof mod.rawContent === 'function' ? mod.rawContent() : '';
    const firstH1Match = rawContent.match(/^#\s+(.+)$/mu);
    const title = firstH1Match ? firstH1Match[1] : slug;
    const number = slug.match(/^(\d+)/u)?.[1] ?? '';
    return {
      params: { slug },
      props: { Content: mod.Content, title, number },
    };
  });
}

const { Content, title, number } = Astro.props;
---

<DocsLayout title={title} description={`ADR-${number}: ${title}`}>
  <section class="gw-section">
    <div class="gw-width gw-prose">
      <p class="gw-caption">ADR-{number}</p>
      <Content />
    </div>
  </section>
</DocsLayout>
