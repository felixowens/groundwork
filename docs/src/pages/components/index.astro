---
import { componentDocs } from '../../docs-registry';
import DocsLayout from '../../layouts/DocsLayout.astro';
---

<DocsLayout title="Components" description="Groundwork component documentation">
  <section class="gw-section">
    <div class="gw-width gw-stack--lg">
      <div class="gw-prose">
        <h1 class="gw-heading-l">Components</h1>
        <p>Groundwork components are intentionally small and restrictive. Use them to keep application UI consistent without repeating accessibility wiring by hand.</p>
        <p>For forms, start with Field. It connects labels, hints, errors, and ARIA attributes before the control reaches the page.</p>
      </div>

      <div class="gw-grid">
        {
          componentDocs.map((component) => (
            <article class="gw-card gw-stack--sm">
              <h2 class="gw-heading-s">
                <a href={component.href}>{component.label}</a>
              </h2>
              <p class="gw-body--sm">{component.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</DocsLayout>
