---
interface Props {
  token: string;
  rem: string;
  px: string;
}

const { token, rem, px } = Astro.props;
---

<li class="docs-spacing-step">
  <div class="docs-spacing-step__bar" style={`inline-size: var(${token})`} aria-hidden="true" />
  <div class="docs-spacing-step__meta">
    <code class="gw-mono docs-spacing-step__token">{token}</code>
    <span class="docs-spacing-step__value">{rem} / {px}</span>
  </div>
</li>

<style>
  .docs-spacing-step {
    display: grid;
    grid-template-columns: minmax(160px, 1fr) auto;
    align-items: center;
    gap: var(--space-4);
    list-style: none;
  }

  .docs-spacing-step__bar {
    block-size: 24px;
    background: var(--action);
    border-radius: var(--radius-sm);
    min-inline-size: 4px;
  }

  .docs-spacing-step__meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    text-align: end;
  }

  .docs-spacing-step__token {
    font-size: var(--text-body);
    color: var(--ink);
  }

  .docs-spacing-step__value {
    font-size: var(--text-caption);
    color: var(--ink-secondary);
    font-family: var(--font-mono);
  }
</style>
