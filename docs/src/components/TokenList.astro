---
interface Entry {
  term: string;
  description: string;
}

interface Props {
  entries: readonly Entry[];
}

const { entries } = Astro.props;
---

<dl class="docs-token-list gw-card">
  {
    entries.map((entry) => (
      <div class="docs-token-list__row">
        <dt set:html={entry.term} />
        <dd set:html={entry.description} />
      </div>
    ))
  }
</dl>

<style>
  .docs-token-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin: 0;
  }

  .docs-token-list__row {
    display: grid;
    grid-template-columns: minmax(160px, 14rem) 1fr;
    gap: var(--space-4);
    align-items: baseline;
  }

  .docs-token-list__row dt {
    margin: 0;
  }

  .docs-token-list__row dd {
    margin: 0;
    font-size: var(--text-secondary);
    color: var(--ink-secondary);
  }

  @media (max-width: 600px) {
    .docs-token-list__row {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
