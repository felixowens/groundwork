{
  "name": "@groundwork/ui",
  "version": "0.0.0-poc",
  "description": "An opinionated design system for web applications: two-tier tokens, plain CSS, and restrictive React components.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css/groundwork.css": "./css/groundwork.css"
  },
  "files": [
    "css",
    "dist",
    "tokens"
  ],
  "scripts": {
    "build:tokens": "style-dictionary build --config style-dictionary.config.mjs",
    "build:css": "npm run build:tokens && node scripts/build-css.mjs",
    "check:css": "node scripts/check-css-architecture.mjs",
    "typecheck": "tsc --noEmit",
    "build:lib": "tsc -p tsconfig.build.json",
    "docs:dev": "astro dev --root docs",
    "docs:build": "astro build --root docs",
    "docs:preview": "astro preview --root docs --host 127.0.0.1",
    "review:ui": "node dev-tools/review-ui.mjs",
    "build": "npm run build:css && npm run build:lib && npm run docs:build",
    "test:a11y": "playwright test tests/a11y",
    "test:components": "playwright test tests/components",
    "test:flows": "playwright test tests/flows",
    "test:visual": "playwright test tests/visual",
    "check:generated-css": "node scripts/check-generated-css.mjs",
    "test": "npm run test:a11y && npm run test:components && npm run test:flows && npm run test:visual",
    "ci": "npm run build:css && npm run check:generated-css && npm run check:css && npm run typecheck && npm run build && npm test"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@astrojs/mdx": "5.0.4",
    "@astrojs/react": "5.0.4",
    "@axe-core/playwright": "4.11.3",
    "@playwright/test": "1.59.1",
    "@types/node": "25.6.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "astro": "6.3.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "style-dictionary": "5.4.0",
    "typescript": "6.0.3"
  }
}
