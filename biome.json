{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!node_modules",
      "!docs/node_modules",
      "!dist",
      "!docs/dist",
      "!docs/.astro",
      "!**/*.astro",
      "!meta/artifacts",
      "!src/styles/generated",
      "!css/groundwork.css",
      "!package-lock.json",
      "!test-results",
      "!playwright-report",
      "!.logs"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noGlobalObjectCalls": "error",
        "noUnreachable": "error",
        "noUnusedFunctionParameters": "error",
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "useExhaustiveDependencies": "error",
        "useHookAtTopLevel": "error",
        "useParseIntRadix": "error"
      },
      "suspicious": {
        "noCompareNegZero": "error",
        "noConsole": "error",
        "noDebugger": "error",
        "noDoubleEquals": "error",
        "noExplicitAny": "error",
        "noReactForwardRef": "error",
        "noTsIgnore": "error",
        "noVar": "error",
        "useAwait": "error",
        "useErrorMessage": "error"
      },
      "style": {
        "noDefaultExport": "error",
        "noDescendingSpecificity": "error",
        "noEnum": "error",
        "noImplicitBoolean": "error",
        "noNegationElse": "error",
        "noNestedTernary": "error",
        "noNonNullAssertion": "error",
        "noParameterAssign": "error",
        "noUselessElse": "error",
        "useBlockStatements": "error",
        "useConsistentTypeDefinitions": "error",
        "useConst": "error",
        "useDeprecatedReason": "error",
        "useExportType": "error",
        "useFilenamingConvention": "error",
        "useImportType": "error",
        "useNodejsImportProtocol": "error",
        "useSelfClosingElements": "error",
        "useTemplate": "error",
        "useThrowNewError": "error",
        "useThrowOnlyError": "error"
      },
      "complexity": {
        "noForEach": "error",
        "noUselessStringConcat": "error",
        "noUselessTernary": "error",
        "noUselessUndefined": "error",
        "useDateNow": "error",
        "useFlatMap": "error",
        "useIndexOf": "error",
        "useLiteralKeys": "error",
        "useOptionalChain": "error",
        "useRegexLiterals": "error",
        "useWhile": "error"
      },
      "performance": {
        "noAccumulatingSpread": "error",
        "noAwaitInLoops": "error",
        "useTopLevelRegex": "error"
      },
      "nursery": {
        "noFloatingPromises": "error",
        "noMisusedPromises": "error",
        "noMultiAssign": "error",
        "noShadow": "error",
        "noUnsafePlusOperands": "error",
        "useErrorCause": "error",
        "useExhaustiveSwitchCases": "error",
        "useNullishCoalescing": "error"
      },
      "security": {
        "noBlankTarget": "error",
        "noDangerouslySetInnerHtml": "error",
        "noSecrets": "error"
      }
    },
    "domains": {
      "playwright": "recommended",
      "react": "recommended",
      "project": "recommended",
      "test": "recommended",
      "types": "recommended"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "overrides": [
    {
      "includes": ["docs/astro.config.mjs", "playwright.config.ts", "style-dictionary.config.mjs"],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "includes": ["tests/**/*.ts"],
      "linter": {
        "rules": {
          "performance": {
            "useTopLevelRegex": "off"
          }
        }
      }
    }
  ]
}
