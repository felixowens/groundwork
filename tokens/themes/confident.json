{
  "$type": "color",
  "primitives": {
    "neutral": {
      "0": { "$value": "#FFFFFF" },
      "50": { "$value": "#F6F1EB" },
      "100": { "$value": "#F1EAE2" },
      "200": { "$value": "#E9E0D6" },
      "300": { "$value": "#D7CCC0" },
      "400": { "$value": "#A89E92" },
      "500": { "$value": "#7C7468" },
      "600": { "$value": "#5C544C" },
      "700": { "$value": "#3E372F" },
      "800": { "$value": "#211C17" },
      "900": { "$value": "#1A1714" },
      "950": { "$value": "#110E0C" }
    },
    "accent": {
      "100": { "$value": "#E2E7FF" },
      "200": { "$value": "#A9B8FF" },
      "300": { "$value": "#8094FF" },
      "400": { "$value": "#4A6BFF" },
      "500": { "$value": "#2547E0" },
      "600": { "$value": "#1A38C0" }
    },
    "danger": {
      "100": { "$value": "#FCE7E4" },
      "200": { "$value": "#EBA9A2" },
      "300": { "$value": "#E07A6F" },
      "400": { "$value": "#D33B2C" },
      "500": { "$value": "#C32A1E" },
      "600": { "$value": "#9E2016" }
    },
    "positive": {
      "100": { "$value": "#E4F4E9" },
      "200": { "$value": "#A9DCBA" },
      "300": { "$value": "#5FB97E" },
      "400": { "$value": "#2E9355" },
      "500": { "$value": "#1E7A40" }
    },
    "caution": {
      "100": { "$value": "#FBEFD9" },
      "300": { "$value": "#E0A94E" },
      "500": { "$value": "#8A5A12" }
    },
    "focus": {
      "400": { "$value": "#FFD23D" }
    },
    "radius": {
      "$type": "dimension",
      "sm": { "$value": "10px" },
      "md": { "$value": "16px" }
    },
    "shadow": {
      "sm": { "$value": "0 1px 2px rgba(26, 23, 20, 0.06)" },
      "md": { "$value": "0 6px 18px -8px rgba(37, 71, 224, 0.35)" },
      "dark": {
        "sm": { "$value": "0 1px 2px rgba(0, 0, 0, 0.3)" },
        "md": { "$value": "0 8px 24px -8px rgba(0, 0, 0, 0.5)" }
      }
    }
  },
  "leading": {
    "normal": { "$type": "number", "$value": "1.5" }
  },
  "font": {
    "display": { "$type": "fontFamily", "$value": "'Bricolage Grotesque', system-ui, sans-serif" }
  }
}
