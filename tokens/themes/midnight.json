      "400": { "$value": "#DE3B3B" },
      "500": { "$value": "#C42A2A" },
      "600": { "$value": "#9E2020" }
    },
    "positive": {
      "100": { "$value": "#E3F6EC" },
      "200": { "$value": "#A9E6C2" },
