      "500": { "$value": "#8A6212" }
    },
    "focus": {
      "400": { "$value": "#FFD23D" }
    },
    "radius": {
      "$type": "dimension",
      "sm": { "$value": "9px" },
      "md": { "$value": "14px" }
    },
    "shadow": {
      "sm": { "$value": "0 1px 2px rgba(0, 0, 0, 0.08)" },
