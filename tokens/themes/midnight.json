        "md": { "$value": "0 10px 28px -10px rgba(0, 0, 0, 0.6)" }
      }
    }
  },
  "leading": {
    "normal": { "$type": "number", "$value": "1.55" }
  },
  "font": {
    "sans": { "$type": "fontFamily", "$value": "'Manrope', system-ui, sans-serif" },
    "display": { "$type": "fontFamily", "$value": "'Manrope', system-ui, sans-serif" }
  }
