{
  "$type": "color",
  "primitives": {
    "neutral": {
      "0": { "$value": "#FFFFFF" },
      "50": { "$value": "#FAF5EA" },
      "100": { "$value": "#F3ECDD" },
      "200": { "$value": "#ECE1CC" },
      "300": { "$value": "#DDCFB4" },
      "400": { "$value": "#A89A82" },
      "500": { "$value": "#7A6E58" },
      "600": { "$value": "#574E3C" },
      "700": { "$value": "#3A3324" },
      "800": { "$value": "#1F1B12" },
      "900": { "$value": "#1A1714" },
      "950": { "$value": "#100E0A" }
    },
    "accent": {
      "100": { "$value": "#ECE6FE" },
      "200": { "$value": "#C4B4FB" },
      "300": { "$value": "#A88FF6" },
      "400": { "$value": "#8056F0" },
      "500": { "$value": "#6D28D9" },
      "600": { "$value": "#5A1FB5" }
    },
    "danger": {
      "100": { "$value": "#FFE7E7" },
      "200": { "$value": "#F2A8AE" },
      "300": { "$value": "#E5727B" },
      "400": { "$value": "#DE3A4A" },
      "500": { "$value": "#CE2436" },
      "600": { "$value": "#A81B2B" }
    },
    "positive": {
      "100": { "$value": "#E6F6EE" },
      "200": { "$value": "#A9E0C0" },
      "300": { "$value": "#4FBD7C" },
      "400": { "$value": "#2A9355" },
      "500": { "$value": "#1E8048" }
    },
    "caution": {
      "100": { "$value": "#FBEBD7" },
      "300": { "$value": "#DBA250" },
      "500": { "$value": "#8A5410" }
    },
    "focus": {
      "400": { "$value": "#F5B91F" }
    },
    "radius": {
      "$type": "dimension",
      "sm": { "$value": "10px" },
      "md": { "$value": "16px" }
    },
    "shadow": {
      "sm": { "$value": "2px 2px 0 0 #1A1714" },
      "md": { "$value": "4px 4px 0 0 #1A1714" },
      "dark": {
        "sm": { "$value": "2px 2px 0 0 #000000" },
        "md": { "$value": "4px 4px 0 0 #000000" }
      }
    }
  },
  "leading": {
    "normal": { "$type": "number", "$value": "1.5" }
  },
  "border": {
    "$type": "color",
    "$value": "{primitives.neutral.800}"
  },
  "border-strong": {
    "$type": "color",
    "$value": "{primitives.neutral.900}"
  },
  "font": {
    "sans": { "$type": "fontFamily", "$value": "'Plus Jakarta Sans', system-ui, sans-serif" },
    "display": { "$type": "fontFamily", "$value": "'Plus Jakarta Sans', system-ui, sans-serif" }
  }
}
